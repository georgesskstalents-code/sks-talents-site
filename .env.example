# ─────────────────────────────────────────────────────────────────────
# SKS TALENTS — Environment variables (template)
# Real values live in .env.local (dev) and Vercel env vars (production).
# Never commit real values to git.
# ─────────────────────────────────────────────────────────────────────

# ── SITE (canonical URLs used by sitemap, OG, schema) ──
NEXT_PUBLIC_SITE_URL=https://www.skstalents.fr
SITE_URL=https://www.skstalents.fr

# ── EMAIL ROUTING ──
CONTACT_NOTIFICATION_EMAIL=g.kengue@skstalents.com
SITE_INTELLIGENCE_EMAIL=g.kengue@skstalents.com
FEEDBACK_NOTIFICATION_EMAIL=g.kengue@skstalents.com
MAIL_FROM_EMAIL=no-reply@skstalents.com

# ── EMAILING (Resend) ──
RESEND_API_KEY=

# ── ANTI-BOT (Cloudflare Turnstile) ──
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── CALENDLY (booking) ──
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/g-kengue-skstalents/30min
CALENDLY_URL=https://calendly.com/g-kengue-skstalents/30min

# ── NOTION (CMS + sitemap fallback) ──
NOTION_TOKEN=
NOTION_VERSION=2022-06-28
NOTION_SITE_DATABASE_ID=
NOTION_ARTICLES_DATABASE_ID=
NOTION_JOB_ROLES_DATABASE_ID=
NOTION_DB_NOTES_ID=
NOTION_DB_ACTIONS_ID=
NOTION_CONTENT_SYNC_SECRET=
NOTION_READ_TIMEOUT_MS=8000

# ── DASHBOARD (private token to access /dashboard) ──
DASHBOARD_PRIVATE_TOKEN=

# ── AI ASSISTANTS (site assistant + orientation report) ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SITE_ASSISTANT_USE_AI=

# ── SUPABASE (leads + feedback storage) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LEADS_TABLE=site_leads
SUPABASE_FEEDBACK_TABLE=site_feedback

# ── KV / UPSTASH (rate-limit + cache) ──
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── EXTERNAL WEBHOOKS (optional — n8n / Make) ──
CALLBACK_WEBHOOK_URL=
LEADS_WEBHOOK_URL=
FEEDBACK_WEBHOOK_URL=

# ── ANALYTICS / VERIFICATION ──
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── WIDGETS (Trustpilot / Senja / Chatwoot) ──
NEXT_PUBLIC_SENJA_WIDGET_ID=
NEXT_PUBLIC_TRUSTPILOT_BUSINESS_UNIT_ID=
NEXT_PUBLIC_TRUSTPILOT_TEMPLATE_ID=
TRUSTPILOT_WIDGET_ID=
NEXT_PUBLIC_CHATWOOT_BASE_URL=
NEXT_PUBLIC_CHATWOOT_WEBSITE_TOKEN=

# ── VIMEO (hero video) ──
NEXT_PUBLIC_VIMEO_VIDEO_ID=
VIMEO_VIDEO_ID=

# ── PURPLE (talent platform link) ──
NEXT_PUBLIC_PURPLE_URL=

# ── LOG PATHS (dev only — defaults work in prod) ──
SITE_ANALYTICS_LOG_PATH=
SITE_FEEDBACK_LOG_PATH=
SITE_FEEDBACK_DIGEST_STATE_PATH=
SITE_LEAD_LOG_PATH=
SITE_SEARCH_LOG_PATH=
