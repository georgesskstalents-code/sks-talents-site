{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/content-digest",
      "schedule": "30 7 * * 1"
    },
    {
      "path": "/api/seo/refresh",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/seo-keywords",
      "schedule": "0 5 * * 1"
    }
  ]
}
